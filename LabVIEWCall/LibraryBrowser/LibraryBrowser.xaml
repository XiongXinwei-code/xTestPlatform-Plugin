<Window x:Class="LibraryBrowser.LibraryBrowserWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LibraryBrowser"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
             mc:Ignorable="d" 
             Title="库浏览器"
             d:DesignHeight="450" d:DesignWidth="600"
             Icon="pack://application:,,,/LibraryBrowser;component/Resources/Icons/library.png"
             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=Windows11Light}">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 选中项路径显示 -->
        <Border Grid.Row="0" 
                BorderThickness="0,0,0,1"
                Padding="10,8">
            <TextBox x:Name="SelectedPathTextBox"
                         IsReadOnly="True"
                         Text="请选择一个库项..."
                         Background="Transparent"
                         BorderThickness="0"
                         VerticalAlignment="Center"
                         FontSize="13"
                         TextWrapping="NoWrap"/>
        </Border>

        <!-- TreeGrid 显示库结构 - 使用 Syncfusion SfTreeGrid，单列显示 -->
        <syncfusion:SfTreeGrid x:Name="LibraryTreeGrid" 
                               Grid.Row="1" 
                               Margin="0"
                               BorderThickness="0"
                               ItemsSource="{Binding}"
                               ChildPropertyName="Children"
                               AutoExpandMode="AllNodesExpanded"
                               SelectionMode="Single"
                               AllowEditing="False"
                               AllowResizingColumns="False"
                               HeaderRowHeight="0"
                               AutoGenerateColumns="False"
                               SelectionChanged="LibraryTreeGrid_SelectionChanged"
                               MouseDoubleClick="LibraryTreeGrid_MouseDoubleClick">

            <syncfusion:SfTreeGrid.Columns>
                <!-- 名称列 (带图标和树形结构) -->
                <syncfusion:TreeGridTextColumn HeaderText="名称" 
                                               MappingName="Name" 
                                               ColumnSizer="Star">
                    <syncfusion:TreeGridTextColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Margin="4,2">
                                <!-- 图标 - 使用 Image 控件 -->
                                <Image Source="{Binding IconImage}" 
                                       Width="16" 
                                       Height="16"
                                       Margin="0,0,8,0" 
                                       VerticalAlignment="Center">
                                    <Image.Style>
                                        <Style TargetType="Image">
                                            <!-- 如果 IconImage 为空，则隐藏 -->
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IconImage}" Value="{x:Null}">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                </DataTrigger>
                                                <!-- 缺失文件图标设置为半透明 -->
                                                <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                    <Setter Property="Opacity" Value="0.5"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Image.Style>
                                </Image>
                                <!-- 名称 -->
                                <TextBlock Text="{Binding Name}" 
                                           ToolTip="{Binding FullPath}"
                                           FontSize="13"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Style.Triggers>
                                                <!-- 缺失文件：红色、删除线、斜体 -->
                                                <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                    <Setter Property="Foreground" Value="#D32F2F"/>
                                                    <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                    <Setter Property="FontStyle" Value="Italic"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </DataTemplate>
                    </syncfusion:TreeGridTextColumn.CellTemplate>
                </syncfusion:TreeGridTextColumn>
            </syncfusion:SfTreeGrid.Columns>
        </syncfusion:SfTreeGrid>

        <!-- 按钮区域 -->
        <Border Grid.Row="2" 
                BorderThickness="0,1,0,0"
                Padding="10,8">
            <StackPanel Orientation="Horizontal" 
                        HorizontalAlignment="Right">
                <syncfusion:ButtonAdv x:Name="RefreshButton" 
                                      Label="刷新"
                                      SmallIcon="pack://application:,,,/LibraryBrowser;component/Resources/Icons/refresh.png"
                                      Click="RefreshButton_Click"
                                      Margin="0,0,10,0" 
                                      Height="26" 
                                      Width="85"/>

                <syncfusion:ButtonAdv x:Name="OkButton" 
                                      Label="确定" 
                                      SmallIcon="pack://application:,,,/LibraryBrowser;component/Resources/Icons/check.png"
                                      Click="OkButton_Click"
                                      Height="26" 
                                      Width="85"
                                      Margin="0,0,10,0">
                </syncfusion:ButtonAdv>

                <syncfusion:ButtonAdv x:Name="CancelButton" 
                                      Label="取消" 
                                      SmallIcon="pack://application:,,,/LibraryBrowser;component/Resources/Icons/cancel.png"
                                      Click="CancelButton_Click"
                                      Height="26" 
                                      Width="85">
                </syncfusion:ButtonAdv>
            </StackPanel>
        </Border>
    </Grid>
</Window>