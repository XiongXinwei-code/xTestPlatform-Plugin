<UserControl x:Class="LabVIEWCallPlugin.UI.Views.LabVIEWCallEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:lvadp="clr-namespace:LabVIEWCallPlugin.UI.Views"
             mc:Ignorable="d"
             d:DesignHeight="350"
             d:DesignWidth="800"
             x:Name="Root">

    <UserControl.Resources>
        <Style x:Key="IconButtonStyle" TargetType="Button">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background" Value="LightGray"/>
            <Setter Property="Width" Value="24"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect Color="Black"
                                      BlurRadius="5"
                                      ShadowDepth="2"
                                      Opacity="0.3"
                                      Direction="315"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect Color="Black"
                                              BlurRadius="10"
                                              ShadowDepth="3"
                                              Opacity="0.5"
                                              Direction="315"/>
                        </Setter.Value>
                    </Setter>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <syncfusion:TabControlExt CloseButtonType="Hide"
                              AllowDragDrop="False"
                              EnableLabelEdit="False">

        <syncfusion:TabItemExt Header="LabVIEWCall"
                               Image="pack://application:,,,/LabVIEWCall.StepPlugin.UI;component/Resources/Icons/labview.png"
                               ImageHeight="20" ImageWidth="20">
            <Grid Margin="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Row 0: VI 路径输入栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <syncfusion:SfTextBoxExt x:Name="ViPathTextBox"
                     Width="550"
                     Margin="0,0,10,0"
                     Watermark="VI Path..."
                     Text="{Binding Setting.ViFilePath, ElementName=Root, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     IsReadOnly="True"
                     Focusable="False"
                     IsTabStop="False"
                     TextChanged="ViPathTextBox_TextChanged"
                     Background="{DynamicResource ContentBackgroundAlt1}"
                     Cursor="Arrow"/>

            <Button x:Name="BrowseButton"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTip="选择VI文件..."
                    Margin="0,0,5,0"
                    Click="BrowseButton_Click">
                <materialDesign:PackIcon Kind="OpenInBrowser" Width="16" Height="16"/>
            </Button>

            <Button x:Name="EditButton"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTip="编辑VI文件..."
                    Margin="0,0,5,0"
                    Click="EditButton_Click">
                <materialDesign:PackIcon Kind="EditBox" Width="16" Height="16"/>
            </Button>

            <Button x:Name="ReLoadButton"
                    Style="{StaticResource IconButtonStyle}"
                    ToolTip="刷新VI文件..."
                    Margin="0,0,5,0"
                    Click="ReLoadButton_Click">
                <materialDesign:PackIcon Kind="Reload" Width="16" Height="16"/>
            </Button>
        </StackPanel>

        <!-- Row 1: Show / Close 复选框 -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="10,0,10,10">
            <CheckBox Content="Show VI front panel when called"
                      IsChecked="{Binding Setting.ShowPanel, ElementName=Root, Mode=TwoWay}"
                      VerticalAlignment="Center"
                      Margin="0,0,15,0"/>
            <CheckBox Content="Close VI front panel when done"
                      IsChecked="{Binding Setting.ClosePanel, ElementName=Root, Mode=TwoWay}"
                      VerticalAlignment="Center"/>
        </StackPanel>

        <!-- Row 2: LvPanelView 参数面板 -->
        <lvadp:LvPanelView x:Name="LvPanel"
                           Grid.Row="2"
                           SequenceFile="{Binding SequenceFile, ElementName=Root}"
                           EditPosition="{Binding EditPosition, ElementName=Root}"
                           HorizontalAlignment="Stretch"
                           VerticalAlignment="Stretch"/>
            </Grid>
        </syncfusion:TabItemExt>
    </syncfusion:TabControlExt>
</UserControl>