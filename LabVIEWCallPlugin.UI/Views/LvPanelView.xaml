<UserControl
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LabVIEWCallPlugin.UI.Views"
             xmlns:helpers="clr-namespace:LabVIEWCallPlugin.UI.Converters"
             xmlns:models="clr-namespace:LabVIEWCallPlugin.UI.Models"
             xmlns:syncfusion="http://schemas.syncfusion.com/wpf" 
             xmlns:syncfusionskin="clr-namespace:Syncfusion.SfSkinManager;assembly=Syncfusion.SfSkinManager.WPF"
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:experssion="clr-namespace:ExperssionTextBox;assembly=ExperssionTextBox"
             xmlns:notification="clr-namespace:Syncfusion.Windows.Controls.Notification;assembly=Syncfusion.SfBusyIndicator.WPF"
             x:Class="LabVIEWCallPlugin.UI.Views.LvPanelView"
             mc:Ignorable="d" 
             d:DesignWidth="900" 
             syncfusionskin:SfSkinManager.Theme="{syncfusionskin:SkinManagerExtension ThemeName=Windows11Light}"
             HorizontalAlignment="Stretch"
             VerticalAlignment="Stretch" 
             Focusable="False"
             IsTabStop="False"
             d:DesignHeight="250">
    <UserControl.Resources>
        <helpers:BooleanStringConverter x:Key="BooleanStringConverter"/>
        <helpers:IntegerFormatConverter x:Key="IntegerFormatConverter"/>
        <helpers:EnumValueConverter x:Key="EnumValueConverter"/>
        <helpers:EnumListConverter x:Key="EnumListConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>

        <!-- 枚举值的 ObjectDataProvider -->
        <ObjectDataProvider x:Key="ValueSourceTypeEnum" 
                           MethodName="GetValues" 
                           ObjectType="{x:Type sys:Enum}">
            <ObjectDataProvider.MethodParameters>
                <x:Type TypeName="models:ValueSourceType"/>
            </ObjectDataProvider.MethodParameters>
        </ObjectDataProvider>

        <!-- 右键菜单 - 丢失节点 -->
        <ContextMenu x:Key="MissingNodeContextMenu">
            <MenuItem Header="移除丢失的节点" 
                      Command="{Binding DataContext.RemoveNodeCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      CommandParameter="{Binding}">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="Delete" 
                                            Width="16" 
                                            Height="16"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <!-- 右键菜单 - 正常节点（可扩展） -->
        <ContextMenu x:Key="NormalNodeContextMenu">
            <MenuItem Header="刷新" IsEnabled="False">
                <MenuItem.Icon>
                    <materialDesign:PackIcon Kind="Refresh" 
                                            Width="16" 
                                            Height="16"/>
                </MenuItem.Icon>
            </MenuItem>
        </ContextMenu>

        <!-- Log 编辑模板 -->
        <DataTemplate x:Key="LogEditTemplate">
            <CheckBox IsChecked="{Binding Log, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      Margin="5,0"
                      ToolTip="标记此值是否需要记录到文件"/>
        </DataTemplate>

        <!-- Log 显示模板 -->
        <DataTemplate x:Key="LogDisplayTemplate">
            <CheckBox IsChecked="{Binding Log, Mode=OneWay}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center"
                      IsHitTestVisible="False"
                      Focusable="False"
                      Margin="5,0"
                      ToolTip="标记此值是否需要记录到文件"/>
        </DataTemplate>

        <!-- ValueSourceType 编辑模板 -->
        <DataTemplate x:Key="ValueSourceTypeEditTemplate">
            <ComboBox ItemsSource="{Binding Source={StaticResource ValueSourceTypeEnum}}"
                      SelectedItem="{Binding ValueSourceTypeEnum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Margin="5,0"
                      Padding="5,3">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </DataTemplate>

        <!-- ValueSourceType 显示模板 - 也使用 ComboBox 显示下拉箭头 -->
        <DataTemplate x:Key="ValueSourceTypeDisplayTemplate">
            <ComboBox ItemsSource="{Binding Source={StaticResource ValueSourceTypeEnum}}"
                      SelectedItem="{Binding ValueSourceTypeEnum, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      Margin="5,0"
                      Padding="5,3"
                      BorderThickness="0"
                      Background="Transparent">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding}"/>
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>
        </DataTemplate>

        <!-- 浮点数编辑模板 -->
        <DataTemplate x:Key="NumericEditTemplate">
            <syncfusion:DoubleTextBox Grid.Column="0"
                                      Value="{Binding ActualValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      MinValue="-9999999"
                                      MaxValue="9999999"
                                      NumberDecimalDigits="6"
                                      NumberGroupSeparator="."
                                      ScrollInterval="0.1"/>
        </DataTemplate>

        <!-- 整数编辑模板 - 带格式选择器 -->
        <DataTemplate x:Key="IntegerEditTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox Grid.Column="0" 
                         VerticalContentAlignment="Center"
                         BorderThickness="1"
                         Padding="3">
                    <TextBox.Text>
                        <MultiBinding Converter="{StaticResource IntegerFormatConverter}" Mode="TwoWay" UpdateSourceTrigger="PropertyChanged">
                            <Binding Path="Value"/>
                            <Binding Path="IntegerFormat"/>
                        </MultiBinding>
                    </TextBox.Text>
                </TextBox>

                <ComboBox Grid.Column="1" 
                          Width="80"
                          Margin="3,0,0,0"
                          SelectedValue="{Binding IntegerFormat, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          SelectedValuePath="Tag">
                    <ComboBoxItem Content="Dec" Tag="Decimal"/>
                    <ComboBoxItem Content="Hex" Tag="Hexadecimal"/>
                    <ComboBoxItem Content="Bin" Tag="Binary"/>
                </ComboBox>
            </Grid>
        </DataTemplate>

        <!-- 布尔编辑模板 -->
        <DataTemplate x:Key="BooleanEditTemplate">
            <CheckBox Grid.Column="0"
                          IsChecked="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource BooleanStringConverter}}"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"/>
        </DataTemplate>

        <!-- 字符串编辑模板 -->
        <DataTemplate x:Key="StringEditTemplate">
            <TextBox Grid.Column="0"
                         Text="{Binding Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0"/>
        </DataTemplate>

        <!-- 枚举编辑模板 -->
        <DataTemplate x:Key="EnumEditTemplate">
            <ComboBox Grid.Column="0"
                          ItemsSource="{Binding EnumValues}"
                          SelectedItem="{Binding EnumCurrentValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          VerticalContentAlignment="Center"
                          Padding="5,3"
                          SelectionChanged="EnumComboBox_SelectionChanged"
                          Tag="{Binding}"/>
        </DataTemplate>
        
        <!-- 变量编辑模板 -->
        <DataTemplate x:Key="VariableEditTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding Variable, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         BorderThickness="0"/>
                <syncfusion:ButtonAdv Grid.Column="1"
                            SizeMode="Small"
                            ToolTip="VariableView"
                            SmallIcon ="pack://application:,,,/LabVIEWCall.StepPlugin.UI;component/Resources/Icons/variable.png"
                            Width="24" 
                            Margin="0,0,5,0"
                            Command="{Binding DataContext.OpenVariableViewCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                            CommandParameter="{Binding}"/>
            </Grid>
        </DataTemplate>

        <!-- 浮点数显示模板 -->
        <DataTemplate x:Key="NumericDisplayTemplate">

            <TextBlock Grid.Column="0"
                           Text="{Binding FormattedValue}" 
                           VerticalAlignment="Center"/>
        </DataTemplate>

        <!-- 整数显示模板 - 显示格式化后的值 -->
        <DataTemplate x:Key="IntegerDisplayTemplate">
            <TextBlock Grid.Column="0" 
                           Text="{Binding FormattedValue}"
                           VerticalAlignment="Center" 
                           Padding="5,0"/>
        </DataTemplate>

        <!-- 布尔显示模板 - 使用 CheckBox 但只读 -->
        <DataTemplate x:Key="BooleanDisplayTemplate">
            <CheckBox Grid.Column="0" 
                          IsChecked="{Binding Value, Mode=OneWay, Converter={StaticResource BooleanStringConverter}}"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          IsHitTestVisible="False"
                          Focusable="False"/>
        </DataTemplate>

        <!-- 字符串显示模板 -->
        <DataTemplate x:Key="StringDisplayTemplate">
            <TextBlock Grid.Column="0" 
                           Text="{Binding Value}" 
                           VerticalAlignment="Center"
                           Padding="5,0"/>
        </DataTemplate>

        <!-- 枚举显示模板 -->
        <DataTemplate x:Key="EnumDisplayTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" 
                           VerticalAlignment="Center"
                           Padding="5,0">
                    <TextBlock.Text>
                        <MultiBinding Converter="{StaticResource EnumValueConverter}">
                            <Binding Path="Value"/>
                            <Binding Path="Value"/>
                        </MultiBinding>
                    </TextBlock.Text>
                </TextBlock>
            </Grid>
        </DataTemplate>

        <!-- 变量显示模板 -->
        <DataTemplate x:Key="VariableDisplayTemplate">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" 
                           Text="{Binding Variable}" 
                           VerticalAlignment="Center"
                           Padding="5,0"/>
                <syncfusion:ButtonAdv Grid.Column="1"
                            SizeMode="Small"
                            ToolTip="VariableView"
                            SmallIcon ="pack://application:,,,/LabVIEWCall.StepPlugin.UI;component/Resources/Icons/variable.png"
                            Width="24" 
                            Margin="0,0,5,0"/>
            </Grid>
        </DataTemplate>
        

            <!-- 显示模板选择器 -->
        <helpers:ValueEditorTemplateSelector x:Key="ValueDisplaySelector"
                                             NumericTemplate="{StaticResource NumericDisplayTemplate}"
                                             IntegerTemplate="{StaticResource IntegerDisplayTemplate}"
                                             BooleanTemplate="{StaticResource BooleanDisplayTemplate}"
                                             StringTemplate="{StaticResource StringDisplayTemplate}"
                                             EnumTemplate="{StaticResource EnumDisplayTemplate}"/>

        <!-- 编辑模板选择器 -->
        <helpers:ValueEditorTemplateSelector x:Key="ValueEditorSelector"
                                             NumericTemplate="{StaticResource NumericEditTemplate}"
                                             IntegerTemplate="{StaticResource IntegerEditTemplate}"
                                             BooleanTemplate="{StaticResource BooleanEditTemplate}"
                                             StringTemplate="{StaticResource StringEditTemplate}"
                                             EnumTemplate="{StaticResource EnumEditTemplate}"/>
    </UserControl.Resources>

    <UserControl.LayoutTransform>
        <ScaleTransform ScaleX="0.9" ScaleY="0.9"/>
    </UserControl.LayoutTransform>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="400" MinWidth="200" MaxWidth="650"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：TabControlExt 包含两个 TreeGrid -->
        <syncfusion:TabControlExt Grid.Column="0"
                                  Margin="10,5,5,5"
                                  TabStripPlacement="Left"
                                  AllowDragDrop="False"
                                  EnableLabelEdit="False"
                                               Focusable="False"
             IsTabStop="False"
                                  CloseButtonType="Hide">

            <!-- Control 输入参数 Tab -->
            <syncfusion:TabItemExt Header="In" 
                                                Focusable="False"
             IsTabStop="False"
                                   FontWeight="Black">
                <syncfusion:SfTreeGrid x:Name="ControlTreeGrid"
                                       AutoExpandMode="RootNodesExpanded"
                                       AutoGenerateColumns="False"
                                       ChildPropertyName="Children"
                                       ItemsSource="{Binding ControlNodes}"
                                       SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                                       AllowEditing="True"
                                       AllowDrop="False"
                                       EditTrigger="OnDoubleTap"
                                       AllowResizingColumns="True"
                                       Focusable="False"
                                       IsTabStop="False"
                                       GridLinesVisibility="Horizontal"
                                       SelectionMode="Single">
                    <syncfusion:SfTreeGrid.Columns>
                        <!-- 名称列 - 使用 Name 属性，添加 IsMissing 样式和右键菜单 -->
                        <syncfusion:TreeGridTemplateColumn HeaderText="Name" 
                                                           MappingName="Name" 
                                                           AllowSorting="False"
                                                           AllowEditing="False"
                                                           Width="200">
                            <syncfusion:TreeGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" 
                                               VerticalAlignment="Center" 
                                               Padding="5,0"
                                               Background="Transparent">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!-- 默认右键菜单 -->
                                                <Setter Property="ContextMenu" Value="{StaticResource NormalNodeContextMenu}" />

                                                <Style.Triggers>
                                                    <!-- 当 IsMissing 为 True 时应用丢失样式和特定菜单 -->
                                                    <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                        <Setter Property="Foreground" Value="#D32F2F"/>
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        <Setter Property="FontStyle" Value="Italic"/>
                                                        <Setter Property="ToolTip" Value="此节点数据丢失或不可用，右键移除"/>
                                                        <Setter Property="ContextMenu" Value="{StaticResource MissingNodeContextMenu}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </syncfusion:TreeGridTemplateColumn.CellTemplate>
                        </syncfusion:TreeGridTemplateColumn>

                        <!-- 数据类型列 - 使用 Type 属性 -->
                        <syncfusion:TreeGridTextColumn HeaderText="DataType" 
                                                       AllowSorting="False"
                                                       MappingName="Type" 
                                                       AllowEditing="False"
                                                       Width="120"/>

                        <!-- 值来源类型列 - 使用 ValueSourceType，显示和编辑都用 ComboBox -->
                        <syncfusion:TreeGridTemplateColumn HeaderText="Source" 
                                                           MappingName="ValueSourceTypeEnum"
                                                           AllowSorting="False"
                                                           AllowEditing="False"
                                                           CellTemplate="{StaticResource ValueSourceTypeDisplayTemplate}"
                                                           Width="120"/>

                        <!-- Log 列 - 记录标记 -->
                        <syncfusion:TreeGridTemplateColumn HeaderText="Log" 
                                                           MappingName="Log"
                                                           AllowSorting="False"
                                                           AllowEditing="True"
                                                           CellTemplate="{StaticResource LogDisplayTemplate}"
                                                           EditTemplate="{StaticResource LogEditTemplate}"
                                                           Width="60"/>

                        <!-- 值列 - 根据类型自动选择模板 -->
                        <syncfusion:TreeGridTemplateColumn HeaderText="Value" 
                                                           MappingName="Value"
                                                           AllowSorting="False"
                                                           AllowEditing="True"
                                                           Width="280"
                                                           CellTemplateSelector="{StaticResource ValueDisplaySelector}"
                                                           EditTemplateSelector="{StaticResource ValueEditorSelector}"/>
                        
                        <!-- Variable 列 - 绑定到 Variable 属性 -->
                        <syncfusion:TreeGridTemplateColumn HeaderText="Variable" 
                                                           MappingName="Variable"
                                                           AllowSorting="False"
                                                           AllowEditing="True"
                                                           ColumnSizer="Star"
                                                           CellTemplate="{StaticResource VariableDisplayTemplate}"
                                                           EditTemplate="{StaticResource VariableEditTemplate}"/>
                    </syncfusion:SfTreeGrid.Columns>
                </syncfusion:SfTreeGrid>
            </syncfusion:TabItemExt>

            <!-- Indicator 输出参数 Tab -->
            <syncfusion:TabItemExt Header="Out" 
                                   Focusable="False"
                                   IsTabStop="False"
                                   FontWeight="Black">
                <syncfusion:SfTreeGrid x:Name="IndicatorTreeGrid"
                                       AutoExpandMode="AllNodesExpanded"
                                       AutoGenerateColumns="False"
                                       ChildPropertyName="Children"
                                       ItemsSource="{Binding IndicatorNodes}"
                                       SelectedItem="{Binding SelectedNode, Mode=TwoWay}"
                                       AllowEditing="True"
                                       AllowDrop="False"
                                       EditTrigger="OnDoubleTap"
                                       AllowResizingColumns="True"
                                       Focusable="False"
                                       IsTabStop="False"
                                       GridLinesVisibility="Horizontal"
                                       SelectionMode="Single">
                    <syncfusion:SfTreeGrid.Columns>
                        <!-- 名称列 - 添加 IsMissing 样式和右键菜单 -->
                        <syncfusion:TreeGridTemplateColumn HeaderText="Name" 
                                                           MappingName="Name" 
                                                           AllowSorting="False"
                                                           AllowEditing="False"
                                                           Width="200">
                            <syncfusion:TreeGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Name}" 
                                               VerticalAlignment="Center" 
                                               Padding="5,0"
                                               Background="Transparent">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <!-- 默认右键菜单 -->
                                                <Setter Property="ContextMenu" Value="{StaticResource NormalNodeContextMenu}" />

                                                <Style.Triggers>
                                                    <!-- 当 IsMissing 为 True 时应用丢失样式和特定菜单 -->
                                                    <DataTrigger Binding="{Binding IsMissing}" Value="True">
                                                        <Setter Property="Foreground" Value="#D32F2F"/>
                                                        <Setter Property="TextDecorations" Value="Strikethrough"/>
                                                        <Setter Property="FontStyle" Value="Italic"/>
                                                        <Setter Property="ToolTip" Value="此节点数据丢失或不可用，右键移除"/>
                                                        <Setter Property="ContextMenu" Value="{StaticResource MissingNodeContextMenu}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </DataTemplate>
                            </syncfusion:TreeGridTemplateColumn.CellTemplate>
                        </syncfusion:TreeGridTemplateColumn>

                        <!-- 数据类型列 -->
                        <syncfusion:TreeGridTextColumn HeaderText="DataType" 
                                                       AllowSorting="False"
                                                       MappingName="Type" 
                                                       AllowEditing="False"
                                                       Width="120"/>

                        <!-- Log 列 - 记录标记 -->
                        <syncfusion:TreeGridTemplateColumn HeaderText="Log" 
                                                           MappingName="Log"
                                                           AllowSorting="False"
                                                           AllowEditing="True"
                                                           CellTemplate="{StaticResource LogDisplayTemplate}"
                                                           EditTemplate="{StaticResource LogEditTemplate}"
                                                           Width="60"/>

                        <!-- Variable 列 - 绑定到 Variable 属性 -->
                        <syncfusion:TreeGridTemplateColumn HeaderText="Variable" 
                                                           MappingName="Variable"
                                                           AllowSorting="False"
                                                           AllowEditing="True"
                                                           ColumnSizer="Star"
                                                           CellTemplate="{StaticResource VariableDisplayTemplate}"
                                                           EditTemplate="{StaticResource VariableEditTemplate}"/>
                    </syncfusion:SfTreeGrid.Columns>
                </syncfusion:SfTreeGrid>
            </syncfusion:TabItemExt>

        </syncfusion:TabControlExt>

        <!-- 分隔符 -->
        <GridSplitter Grid.Column="1" 
                      Width="4"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Stretch"
                      Background="#E8E8E8"
                      BorderBrush="#CCCCCC"
                      BorderThickness="1,0"
                      ShowsPreview="True"
                      Cursor="SizeWE"/>

        <!-- 右侧:面板图像显示区域 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- 状态栏 -->
            <Border Grid.Row="0"
                    Margin="5,5,10,5"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    Background="#F5F5F5"
                    Padding="8,5">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- VI 状态 -->
                    <TextBlock Grid.Column="0"
                               Text="VI State:"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>
                    <TextBlock Grid.Column="1"
                               Text="{Binding ViStateText}"
                               VerticalAlignment="Center"
                               FontWeight="Normal"
                               Margin="0,0,15,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding ViState}" Value="Bad">
                                        <Setter Property="Foreground" Value="Red"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ViState}" Value="Idle">
                                        <Setter Property="Foreground" Value="Green"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ViState}" Value="Running">
                                        <Setter Property="Foreground" Value="Orange"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding ViState}" Value="RunTopLevel">
                                        <Setter Property="Foreground" Value="Blue"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>

                    <!-- 可重入状态 -->
                    <TextBlock Grid.Column="2"
                               Text="Reentrant:"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>
                    <CheckBox Grid.Column="3"
                              IsChecked="{Binding IsReentrant, Mode=OneWay}"
                              IsEnabled="False"
                              VerticalAlignment="Center"
                              Margin="0,0,15,0"/>

                    <!-- LabVIEW IDE 连接状态 -->
                    <TextBlock Grid.Column="4"
                               Text="LV IDE:"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Margin="0,0,5,0"/>
                    <TextBlock Grid.Column="5"
                               Text="{Binding LabViewIdeStateText}"
                               VerticalAlignment="Center"
                               FontWeight="Normal">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <!-- 默认：Unknown → 灰色 -->
                                <Setter Property="Foreground" Value="Gray"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LabViewIdeState}"
                                                 Value="{x:Static models:LabViewIdeState.Connected}">
                                        <Setter Property="Foreground" Value="Green"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding LabViewIdeState}"
                                                 Value="{x:Static models:LabViewIdeState.Disconnected}">
                                        <Setter Property="Foreground" Value="Red"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- 面板图像 -->
            <Border Grid.Row="1" 
                    Margin="5,0,10,6"
                    BorderBrush="LightGray"
                    BorderThickness="1"
                    Background="White">
                <Grid>
                    <!-- 面板图像 -->
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Auto">
                        <Image Source="{Binding PanelImage}"
                               Stretch="None"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                    </ScrollViewer>

                    <!-- LabVIEW 未连接提示层 -->
                    <Border Background="#CCF5F5F5"
                            Visibility="{Binding IsLabViewDisconnected,
                                         Converter={StaticResource BooleanToVisibilityConverter}}"
                            IsHitTestVisible="False">
                        <StackPanel HorizontalAlignment="Center"
                                    VerticalAlignment="Center"
                                    Orientation="Vertical">
                            <materialDesign:PackIcon Kind="LanDisconnect"
                                                     Width="48"
                                                     Height="48"
                                                     Foreground="#BDBDBD"
                                                     HorizontalAlignment="Center"/>
                            <TextBlock Text="LabVIEW 未连接"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="#9E9E9E"
                                       HorizontalAlignment="Center"
                                       Margin="0,8,0,4"/>
                            <TextBlock Text="请启动 LabVIEW 后点击刷新"
                                       FontSize="12"
                                       Foreground="#BDBDBD"
                                       HorizontalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
        <!-- 加载占位层：在 LoadPanelAsync 未完成时显示，阻止交互 -->
        <Border Background="#80000000"
                Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                Grid.ColumnSpan="3"
                Grid.RowSpan="1"
                IsHitTestVisible="True">
            <Grid>
                <notification:SfBusyIndicator IsBusy="True"
                                              AnimationType="Gear"
                                              Background="White"
                                              Header="Loading..."
                                              Width="240"
                                              Height="80"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
            </Grid>
        </Border>
    </Grid>
</UserControl>